{
  "manifest_version": 3,
  "name": "Ask AI",
  "version": "2.0",
  "description": "Ask AI doubts about YouTube videos using transcript context",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "icons": {
    "16": "icon/icon16.png",
    "32": "icon/icon32.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },
  "action": {
  "default_icon": {
    "16": "icon/icon16.png",
    "32": "icon/icon32.png"
  }
},
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}
